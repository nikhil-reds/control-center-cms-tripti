// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ConnectionStatus {
  ONLINE
  OFFLINE
}

model Media {
  id              String           @id @default(cuid())
  name            String
  type            MediaType
  status          ConnectionStatus @default(ONLINE)
  objectKey       String           @unique
  originalName    String
  mimeType        String
  sourceUrl       String
  thumbnailUrl    String?
  sizeBytes       BigInt
  width           Int?
  height          Int?
  durationSeconds Int?
  activeOn        Display[]        @relation("ActiveMedia")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model Display {
  id            String           @id @default(cuid())
  name          String
  location      String
  resolution    String
  status        ConnectionStatus @default(OFFLINE)
  activeMediaId String?
  activeMedia   Media?           @relation("ActiveMedia", fields: [activeMediaId], references: [id], onDelete: SetNull)
  lastSeenAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
  @@index([activeMediaId])
}
